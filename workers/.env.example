# Copy to .env and fill in values. Never commit .env.

# --- Queue & database ---
# Host Node (npm start on your machine, Redis on localhost):
REDIS_URL=redis://localhost:6379
# Docker Compose uses bundled Redis; worker compose file forces redis://redis:6379 for the container.

MONGO_URI=mongodb://localhost:27017/codesm

# --- AWS (testcases in S3) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# --- Sandbox image (default if unset: codesm-cpp-runner:latest) ---
CPP_RUNNER_IMAGE=codesm-cpp-runner:latest
# true | false | omit (omit allows auto-build when NODE_ENV is not production)
CPP_RUNNER_AUTO_BUILD=

SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_PIDS_LIMIT=64
CPP_COMPILE_TIMEOUT_SEC=60
CPP_RUN_TIMEOUT_SEC=2
MAX_TESTCASE_INPUT_BYTES=262144
MAX_PROGRAM_OUTPUT_BYTES=262144
